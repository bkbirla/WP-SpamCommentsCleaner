# WordPress REST API Settings
WP_URL=https://your-wordpress-site.com
WP_USERNAME=your_wordpress_username
# 24-character WordPress Application Password (spaces are optional, client will strip them)
WP_APP_PASSWORD=abcd efgh ijkl mnop qrst uvwx

# Spam Classifier Settings
# Options: heuristic, llm, akismet
CLASSIFIER_TYPE=heuristic

# LLM Classifier Settings (required if CLASSIFIER_TYPE=llm)
# Get a key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Akismet Classifier Settings (required if CLASSIFIER_TYPE=akismet)
# Get a key from https://akismet.com/
AKISMET_API_KEY=your_akismet_api_key_here
